# =============================================================================
# Forge AI Workflow Studio — Environment Variables
# Copy this file to .env.local (web) and apps/api/.env (api) and fill in values
# =============================================================================

# --- Supabase ---
# Found at: https://supabase.com/dashboard/project/<your-project>/settings/api
# Use the same project ref in every URL (anon / publishable key pairs with that project only).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-or-sb_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Legacy HS256 only; new projects often use ES256 + JWKS (can be empty). Dashboard: Settings → API → JWT.
SUPABASE_JWT_SECRET=your-jwt-secret
# Optional: direct Postgres (Settings → Database). Not required for Forge API unless you add SQLAlchemy.
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# --- Next.js Public (prefix with NEXT_PUBLIC_ to expose to browser) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO
# Production: JSON array of allowed browser origins (must include your deployed Next URL)
# CORS_ORIGINS=["https://your-app.vercel.app","http://localhost:3000"]

# --- LLM Providers (add keys for providers you want to use) ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# --- Stripe (Epic 7) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Liveblocks (Epic 8) ---
# Set NEXT_PUBLIC_ENABLE_LIVEBLOCKS=true to sync canvas + cursors (requires LIVEBLOCKS_SECRET_KEY on the server for /api/liveblocks-auth).
# Draft graphs use room forge:new until first save; the auth route allows that room for signed-in users only.
# On first save, the graph is stashed into sessionStorage so the new room (forge:<id>) starts with the same Liveblocks storage.
NEXT_PUBLIC_ENABLE_LIVEBLOCKS=false
LIVEBLOCKS_SECRET_KEY=sk_...
NEXT_PUBLIC_LIVEBLOCKS_PUBLIC_KEY=pk_...

# --- API: per-user encrypted vault (BYOK-style keys at rest) ---
# Optional dedicated pepper; defaults to SUPABASE_JWT_SECRET if unset. Rotate with a migration plan for existing ciphertext.
BYOK_VAULT_PEPPER=

# --- Sentry (Epic 8) ---
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# --- Temporal (Epic 4) ---
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default

# --- Vercel Deploy API (Epic 6) ---
VERCEL_API_TOKEN=your-vercel-token
VERCEL_TEAM_ID=your-team-id

# --- Public API URL (for MCP manifest, webhook docs) ---
API_PUBLIC_URL=http://localhost:8000

# --- E2E Test Credentials (local/staging Playwright) ---
# Create a dedicated non-production Supabase user for these.
E2E_EMAIL=
E2E_PASSWORD=
