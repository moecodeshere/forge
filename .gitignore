# =============================================================================
# Forge — repository root (covers the whole tree, including code/)
# =============================================================================

# --- Dependencies (largest; never commit) ---
node_modules/
.pnpm-store/
.pnpm-debug.log*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- JS/TS builds & caches ---
.next/
out/
dist/
build/
.turbo/
.vercel/
*.tsbuildinfo
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
*.egg-info/
.eggs/
*.egg
.mypy_cache/
.ruff_cache/
.pytest_cache/
.pytype/
htmlcov/
.tox/
*.cover
.hypothesis/
pip-log.txt

# --- Test & coverage ---
coverage/
*.lcov
.nyc_output/

# --- Environment & secrets ---
.env
.env.*
!.env.example
!.env*.example
*.pem
*.key
!**/public/**/*.pem

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- OS ---
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Editors ---
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
*.swp
*.swo
*~

# --- Supabase CLI (local temp only) ---
**/supabase/.temp/
**/supabase/.branches/

# --- Playwright / E2E ---
**/playwright-report/
**/test-results/
**/blob-report/

# --- Misc generated ---
*.local.md
.sentryclirc
